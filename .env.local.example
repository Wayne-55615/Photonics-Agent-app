# Photonic Platform Frontend — environment template.
# Copy to .env.local for local dev (gitignored), or set in Vercel project settings.
#
# Two-tier prefix convention:
#   NEXT_PUBLIC_*  → exposed to the browser (used in app/page.tsx, app/abstats/...)
#   no prefix      → server-side only (used in app/api/*/route.ts)

# ─── Server-side (used by /api/* route handlers) ────────────────────────
# Browser never talks to n8n directly — main chat hits /api/chat (proxy),
# /abstats test query hits /api/a-chat. The upstream URLs are configured
# here, server-side only, so n8n can stay on a docker-internal network.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/invoke_n8n_agent
N8N_A_FLOW_URL=http://localhost:5678/webhook/a/agent-chat

# n8n base URL — for /api/optimize-start, /api/optimize-status
N8N_URL=http://localhost:5678

# IPKISS API base — for /api/replay, /api/halfband-recommend, /api/calibrate-fit
IPKISS_URL=http://localhost:8000

# Ollama base — for /api/decide-params, /api/replay-review, /api/calibrate-diagnose
OLLAMA_URL=http://localhost:11434

# GDS Analysis API base — for /api/fig/[...path] and next.config.ts rewrite
GDS_API_URL=http://localhost:8200

# Optional model overrides (default: llama3.1:8b)
# DECIDE_MODEL=llama3.1:8b
# REVIEW_MODEL=llama3.1:8b
# CALIBRATE_MODEL=llama3.1:8b

# ─── Filesystem paths (server-side, used by /api/results & /api/abstats) ─
# Comma-separated absolute paths to IPKISS results dirs. Vercel/cloud deploys
# can't see D:/; either point to a synced/mounted location or leave default
# and only run /api/results locally.
RESULTS_DIRS=D:/photonic-platform/ipkiss-api/results,D:/photonic-platform/ipkiss-api/results_test_dc

# Optional override for the A/B batch JSONL log used by /api/abstats latency
# AB_BATCH_LOG=D:/photonic-platform/scripts/ab_batch.jsonl

# Optional override for skill markdown templates loaded by calibrate/decide/review routes
# CALIBRATE_SKILL_PATH=/path/to/calibrate_skill.md
# DECIDE_SKILL_PATH=/path/to/decide_skill.md
# REVIEW_SKILL_PATH=/path/to/review_skill.md

# ─── Database (server-side, used by /api/abstats and /api/stats) ────────
# pgvector-enabled postgres for sim_run / llm_summary / gds_structures
DATABASE_URL=postgres://n8n:n8n@localhost:5432/n8n
